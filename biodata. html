<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Biodata Diri</title>
    <style>
        /* CSS Langsung di dalam file HTML */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f4f7f6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .card {
            background-color: #fff;
            width: 100%;
            max-width: 450px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            overflow: hidden;
            text-align: center;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 120px;
        }

        .profile-img {
            width: 120px;
            height: 120px;
            background-color: #ddd;
            border-radius: 50%;
            border: 5px solid #fff;
            margin-top: -60px;
            object-fit: cover;
        }

        .content {
            padding: 20px 30px;
        }

        h2 {
            color: #333;
            margin-bottom: 5px;
        }

        p.job {
            color: #764ba2;
            font-weight: 600;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        table tr td {
            padding: 10px 5px;
            text-align: left;
            border-bottom: 1px solid #eee;
            font-size: 14px;
        }

        .label {
            font-weight: bold;
            color: #555;
            width: 40%;
        }

        .value {
            color: #777;
        }

        .footer {
            padding: 20px;
            background-color: #fafafa;
        }

        .btn {
            text-decoration: none;
            background-color: #764ba2;
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            font-size: 14px;
            transition: 0.3s;
        }

        .btn:hover {
            background-color: #667eea;
        }
    </style>
</head>
<body>

    <div class="card">
        <div class="header"></div>
        
        <img src="https://via.placeholder.com/150" alt="Foto Profil" class="profile-img">
        
        <div class="content">
            <h2>Nama Lengkap</h2>
            <p class="job">Web Developer / Mahasiswa</p>

            <table>
                <tr>
                    <td class="label">Tempat Lahir</td>
                    <td class="value">Jakarta</td>
                </tr>
                <tr>
                    <td class="label">Tanggal Lahir</td>
                    <td class="value">01 Januari 2000</td>
                </tr>
                <tr>
                    <td class="label">Alamat</td>
                    <td class="value">Jl. Contoh No. 123, Indonesia</td>
                </tr>
                <tr>
                    <td class="label">Email</td>
                    <td class="value">halo@emailkamu.com</td>
                </tr>
                <tr>
                    <td class="label">Hobi</td>
                    <td class="value">Coding, Membaca, Musik</td>
                </tr>
            </table>
        </div>

        <div class="footer">
            <a href="mailto:halo@emailkamu.com" class="btn">Hubungi Saya</a>
        </div>
    </div>

</body>
</html>
